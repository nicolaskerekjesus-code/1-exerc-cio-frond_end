<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Tabela Vendas Trimestrais</title>
    <style>
        table {
            border-collapse: collapse;
            font-family: 'Times New Roman', Times, serif;
            margin: 20px;
        }
        td {
            border: 2px solid #7f7f7f;
            padding: 8px 14px;
            font-size: 24px;
            color: #000;
            text-align: center;
        }
        /* Cabeçalho Principal (Azul) */
        .cabecalho-principal {
            background-color: #99ccff;
            font-weight: bold;
            font-size: 26px;
        }
        /* Coluna do Ano 2010 (Amarelo) */
        .ano-2010 {
            background-color: #ffff00;
            font-weight: bold;
            width: 80px;
        }
        /* Coluna do Ano 2009 (Verde Claro) */
        .ano-2009 {
            background-color: #99ff66;
            font-weight: bold;
            width: 80px;
        }
        /* Ajuste de largura para os valores */
        .valores {
            width: 120px;
        }
    </style>
</head>
<body>

    <table>
        <tr>
            <td colspan="4" class="cabecalho-principal">Vendas Trimestrais</td>
        </tr>
        
        <tr>
            <td rowspan="3" class="ano-2010">2010</td>
            <td class="valores">144.000</td>
            <td rowspan="3" class="ano-2009">2009</td>
            <td class="valores">188.000</td>
        </tr>
        
        <tr>
            <td>139.580</td>
            <td>179.580</td>
        </tr>
        
        <tr>
            <td>254.900</td>
            <td>298.500</td>
        </tr>
    </table>

</body>
</html>
